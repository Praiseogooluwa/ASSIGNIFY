# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-strong-random-key-here

# ─── Admin credentials ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@assignify.com.ng
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SECRET=generate-another-strong-random-key-here

# ─── CORS — comma separated, no spaces ───────────────────────────────────────
ALLOWED_ORIGINS=https://assignify.com.ng,https://www.assignify.com.ng
